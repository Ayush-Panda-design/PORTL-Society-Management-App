EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key-here
# Optional crash reporting (requires: npx expo install @sentry/react-native + native rebuild)
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Optional for Expo Go email confirmation / OTP magic links (copy from Metro after `expo start`):
# EXPO_PUBLIC_AUTH_REDIRECT_URL=exp://192.168.1.5:8081/--/callback
# Also add that exact URL (and portl://callback) in Supabase → Authentication → URL Configuration
# → Redirect URLs. Site URL can stay https://your-project.supabase.co
# Email OTP: enable Email provider + OTP in Supabase Dashboard → Authentication → Providers
# (Password login stays available; OTP is an extra sign-in option in the app.)
# Optional: override EAS project id for push tokens (also set in app.json extra.eas.projectId)
# EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-uuid
# Razorpay Checkout key (publishable / client).
# EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
#
# Server secrets (set via `supabase secrets set`, not in the app .env):
#   RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
#   RAZORPAY_KEY_SECRET=xxxxxxxx
#   RAZORPAY_WEBHOOK_SECRET=xxxxxxxx
#   GEMINI_API_KEY=...          # Ask Portl + smart complaint triage (free at aistudio.google.com)
#   GEMINI_MODEL=gemini-2.0-flash  # optional
# Webhook URL in Razorpay dashboard:
#   https://<project-ref>.supabase.co/functions/v1/razorpay-webhook
# Enable events: payment.captured (and optionally payment.authorized)
